# Required Keys (Set these securely in Railway)
PRIVATE_KEY=
PROXY_WALLET=

# Bot Configuration
BOT_NAME=tps
MODE=dry
BS_STRATEGY=v621

# Live Simulation Settings (For realistic DRY runs)
BS_LIVE_SIM_ENABLED=true
BS_LIVE_SIM_LATENCY_MS=350
BS_LIVE_SIM_FOK_TOLERANCE=0.001

# Exit Strategy Switches (Keep false for DRY)
BS_BSS_ORPHAN_SELL_ENABLED=false
BS_BSS_ORPHAN_TP_ENABLED=false
BS_BSS_ORPHAN_RS_ENABLED=false

# Other Safeties
SIGNAL_INVERT=false
VALIDATION_MODE=false
BS_USE_POLYMARKET_FEE_FORMULA=true
LOG_TO_DISK=false
DATA_DIR=/data
